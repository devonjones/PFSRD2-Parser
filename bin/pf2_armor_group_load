#!/usr/bin/env python
import sys
import os
import json
import glob
import argparse
from pfsrd2.sql import get_db_path, create_db
from pfsrd2.sql.armor_groups import insert_armor_group, truncate_armor_groups


def load_armor_groups(conn, options):
    path = os.path.join(options.output, "armor_groups")
    assert os.path.exists(path), "JSON Directory doesn't exist: %s" % path
    files = glob.glob(os.path.join(path, "*.json"))
    files = [os.path.abspath(f) for f in files]
    curs = conn.cursor()
    truncate_armor_groups(curs)
    for f in files:
        with open(f) as fp:
            data = json.load(fp)
            sys.stderr.write(data["name"] + "\n")
            insert_armor_group(curs, data)
    conn.commit()


def option_parser(usage):
    parser = argparse.ArgumentParser(usage=usage)
    parser.add_argument(
        "-o",
        "--output",
        dest="output",
        help="Output data directory.  Should be top level directory of psrd data. (required)",
    )
    return parser


def main():
    usage = "usage: %(prog)s [options] [filenames]\nReads armor group json and inserts them into a armor group db"
    parser = option_parser(usage)
    options = parser.parse_args()
    db_path = get_db_path("pfsrd2.db")
    with create_db(db_path) as conn:
        load_armor_groups(conn, options)


if __name__ == "__main__":
    sys.exit(main())
