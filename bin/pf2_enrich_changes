#!/usr/bin/env python3
"""Offline enrichment for template/family change records.

Runs the regex categorization and effect building against raw change
records in the enrichment DB.

Usage:
    pf2_enrich_changes                # Enrich all unenriched records
    pf2_enrich_changes --force        # Re-enrich all (except human-verified)
    pf2_enrich_changes --stats        # Show enrichment statistics
    pf2_enrich_changes --unknown      # Show records that couldn't be categorized
"""

import argparse
import json
import os
import sys

# Add parent directories to path
script_dir = os.path.dirname(os.path.abspath(__file__))
sys.path.insert(0, os.path.join(script_dir, ".."))
sys.path.insert(0, os.path.join(script_dir, "..", "lib"))

from pfsrd2.enrichment.change_extractor import ENRICHMENT_VERSION, enrich_change
from pfsrd2.sql.enrichment import (
    count_change_records,
    fetch_changes_needing_enrichment,
    get_enrichment_db_connection,
    mark_change_needs_review,
    update_change_enriched_json,
)


def main():
    parser = argparse.ArgumentParser(description="Enrich template/family change records")
    parser.add_argument("--stats", action="store_true", help="Show enrichment statistics")
    parser.add_argument("--force", action="store_true", help="Re-enrich all non-verified records")
    parser.add_argument(
        "--unknown", action="store_true", help="Show records that couldn't be categorized"
    )
    parser.add_argument("--sample", type=int, help="Show N sample enriched records")
    args = parser.parse_args()

    conn = get_enrichment_db_connection()
    try:
        curs = conn.cursor()

        if args.stats:
            _show_stats(curs)
            return

        if args.unknown:
            _show_unknown(curs)
            return

        if args.sample:
            _show_sample(curs, args.sample)
            return

        # Run enrichment
        version = 999999 if args.force else ENRICHMENT_VERSION
        records = fetch_changes_needing_enrichment(curs, version)
        print(f"Processing {len(records)} change records (version {ENRICHMENT_VERSION})...")

        enriched_count = 0
        unknown_count = 0
        for record in records:
            enriched_json, method = enrich_change(record["raw_json"], record["source_name"])
            if enriched_json:
                update_change_enriched_json(
                    curs, record["change_id"], enriched_json, ENRICHMENT_VERSION, method
                )
                enriched_count += 1
            else:
                mark_change_needs_review(curs, record["change_id"], "unknown_category")
                unknown_count += 1

        conn.commit()
        print(f"Enriched: {enriched_count}, Unknown: {unknown_count}")
    finally:
        conn.close()


def _show_stats(curs):
    stats = count_change_records(curs)
    print("Change Record Statistics:")
    print(f"  Total:        {stats['total']}")
    print(f"  Enriched:     {stats['enriched']}")
    print(f"  Unenriched:   {stats['unenriched']}")
    print(f"  Stale:        {stats['stale']}")
    print(f"  Verified:     {stats['verified']}")
    print(f"  Needs review: {stats['needs_review']}")

    # Category breakdown
    curs.execute(
        "SELECT json_extract(enriched_json, '$.change_category') as cat, COUNT(*) as cnt "
        "FROM change_records WHERE enriched_json IS NOT NULL "
        "GROUP BY cat ORDER BY cnt DESC"
    )
    rows = curs.fetchall()
    if rows:
        print("\nBy category:")
        for row in rows:
            print(f"  {row['cat'] or 'null':20s} {row['cnt']}")

    # Source type breakdown
    curs.execute("SELECT source_type, COUNT(*) as cnt FROM change_records GROUP BY source_type")
    rows = curs.fetchall()
    if rows:
        print("\nBy source type:")
        for row in rows:
            print(f"  {row['source_type']:20s} {row['cnt']}")


def _show_unknown(curs):
    curs.execute(
        "SELECT source_name, source_type, raw_json FROM change_records "
        "WHERE needs_review = 1 ORDER BY source_name"
    )
    rows = curs.fetchall()
    print(f"Unknown/unrecognized changes ({len(rows)}):\n")
    for row in rows:
        raw = json.loads(row["raw_json"])
        text = raw.get("text", "")[:120]
        print(f"  [{row['source_type']}] {row['source_name']}")
        print(f"    {text}")
        print()


def _show_sample(curs, n):
    curs.execute(
        "SELECT source_name, source_type, raw_json, enriched_json "
        "FROM change_records WHERE enriched_json IS NOT NULL "
        "ORDER BY RANDOM() LIMIT ?",
        (n,),
    )
    rows = curs.fetchall()
    for row in rows:
        raw = json.loads(row["raw_json"])
        enriched = json.loads(row["enriched_json"])
        print(f"[{row['source_type']}] {row['source_name']}")
        print(f"  text: {raw.get('text', '')[:100]}")
        print(f"  category: {enriched.get('change_category')}")
        if enriched.get("effects"):
            print(f"  effects: {len(enriched['effects'])} effect(s)")
            for e in enriched["effects"][:2]:
                print(f"    - {e.get('operation')} -> {e.get('target', '')[:60]}")
        print()


if __name__ == "__main__":
    main()
