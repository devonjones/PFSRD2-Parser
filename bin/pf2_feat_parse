#!/usr/bin/env python
import sys

from pfsrd2.feat import parse_feat
from universal.options import exec_main, option_parser


def main():
    usage = "usage: %(prog)s [options] [filenames]\nParses feats from pfsrd2 html to json and writes them to the specified directory"
    parser = option_parser(usage)
    options = parser.parse_args()
    args = options.files
    exec_main(options, args, parse_feat, "feats")


if __name__ == "__main__":
    sys.exit(main())
