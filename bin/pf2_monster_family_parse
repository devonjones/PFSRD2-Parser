#!/usr/bin/env python
import sys

from pfsrd2.monster_family import parse_monster_family
from universal.options import exec_main, option_parser


def main():
    usage = "usage: %(prog)s [options] [filenames]\nParses monster families from pfsrd2 html to json and writes them to the specified directory"
    parser = option_parser(usage)
    options = parser.parse_args()
    args = options.files
    options.subtype = "monster_family"
    exec_main(options, args, parse_monster_family, "monster_families")


if __name__ == "__main__":
    sys.exit(main())
