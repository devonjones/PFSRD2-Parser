#!/usr/bin/env python
import sys
import os

from pfsrd2.spell import parse_spell
from universal.options import exec_main, option_parser


def main():
    usage = "usage: %(prog)s [options] [filenames]\nParses spells from pfsrd2 html to json and writes them to the specified directory"
    parser = option_parser(usage)
    options = parser.parse_args()
    args = options.files
    exec_main(options, args, parse_spell, "spells")


if __name__ == "__main__":
    sys.exit(main())
