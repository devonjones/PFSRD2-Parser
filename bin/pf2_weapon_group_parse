#!/usr/bin/env python
import sys
import os
from pfsrd2.item_group import parse_item_group
from universal.warnings import WarningReporting
from universal.options import exec_main, option_parser


def main():
    usage = "usage: %(prog)s [options] [filenames]\nParses weapon groups from pfsrd2 html to json and writes them to the specified directory"
    parser = option_parser(usage)
    options = parser.parse_args()
    args = options.files
    options.subtype = "weapon_group"
    exec_main(options, args, parse_item_group, "weapon_groups")


if __name__ == "__main__":
    sys.exit(main())
