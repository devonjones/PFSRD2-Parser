      "source_name": "Vampire",
      "source_type": "monster_template",
      "change_text": "- Add a fangs Strike. It deals damage equal to the creature's lowest melee Strike and can be used to Feed. If the creature already has a jaws or fangs Strike, just add the Feed ability.",
      "note": "replace_one_die per RoE elemental rule; no flat-damage fallback",
      "enriched": {
        "change_category": "damage",
        "effects": [
          {
            "item": {
